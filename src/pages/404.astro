---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Página não encontrada"
  description="Esta página não existe."
  fontsHref="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&family=Dancing+Script:wght@400;700&display=swap"
>
  <main class="wrap">
    <p class="emoji" aria-hidden="true">💔</p>
    <h1>Página não encontrada</h1>
    <p class="sub">A página que você procura não existe — mas o carinho continua aqui.</p>
    <a href="/">Voltar ao início</a>
  </main>
</BaseLayout>

<style is:global>
  body {
    margin: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: radial-gradient(circle at 50% 30%, hsl(340deg 75% 68% / 80%) 0%, hsl(280deg 60% 85% / 80%) 70%);
    font-family: "Quicksand", sans-serif;
    color: #4a2740;
    text-align: center;
    padding: 2rem;
  }
  .wrap { max-width: 32rem; }
  .emoji { font-size: 3rem; margin: 0 0 0.5rem; }
  h1 {
    font-family: "Dancing Script", cursive;
    font-size: 3rem;
    margin: 0 0 0.5rem;
    color: #c50000;
  }
  .sub { font-size: 1.15rem; margin: 0 0 2rem; }
  a {
    display: inline-block;
    padding: 0.7rem 1.6rem;
    border-radius: 9999px;
    background: linear-gradient(110deg, #c50000, #991799);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    box-shadow: 0 8px 24px -10px rgba(153, 23, 153, 0.7);
    transition: transform 0.2s ease;
  }
  a:hover { transform: translateY(-2px); }
</style>
